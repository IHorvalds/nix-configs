nnoremap <SPACE> <Nop>
let g:mapleader = " "
set listchars = "tab:» ","trail:·","nbsp=␣"
set noautochdir
set nu
set rnu

set hlsearch
set noshowmode
set ignorecase

set tabstop=8
set shiftwidth=8
set softtabstop=0
set noexpandtab
set smarttab
set smartcase

set mouse="a"

set undodir=~/.vim/undodir
set undofile
